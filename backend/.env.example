# ═══════════════════════════════════════════════════════════════════════════════
# UniVault Backend Configuration Template
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════════

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection String
# Get from: https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?appName=Cluster

# JWT Authentication Secret
# Use a strong random string (e.g., from: https://randomstring.xyz/)
# IMPORTANT: Change this in production!
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=30d


# ─── CORS Configuration (for production hosting)
# Comma-separated list of allowed origins
# Example: CORS_ORIGIN=https://app.example.com,https://www.example.com
CORS_ORIGIN=http://localhost:3000,http://localhost:5000


